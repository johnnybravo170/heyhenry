{
  "name": "heyhenry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:push": "supabase db push",
    "db:generate": "drizzle-kit generate",
    "smoke": "tsx scripts/smoke-foundation.ts",
    "henry:eval": "tsx evals/henry/run.ts",
    "design-tokens:baseline": "tsx scripts/gen-design-token-baseline.ts",
    "monitor": "bash scripts/monitor-health.sh",
    "verify-deploy": "bash scripts/verify-deploy.sh",
    "check-ci": "bash scripts/check-ci.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "!(src/components/ui/**/*).{ts,tsx}": [
      "biome check --write"
    ],
    "*.{ts,tsx}": [
      "vitest related --run"
    ]
  },
