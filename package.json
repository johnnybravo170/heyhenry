    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "sharp": "^0.34.5",
